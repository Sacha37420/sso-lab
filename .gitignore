# Fichiers d'environnement — contiennent des secrets, jamais commités
**/.env
*.env

# Exceptions : les templates sont versionnés
!**/.env.example

# Généré automatiquement par get-ports-list.sh
ports.env

# Registre des ports — géré localement par new-app.sh
.ports
test-angular/
test-django/
test-angular-django/
test-bots/
test-django-angular/
google-agenda/

# Fichier LDAP — contient des mots de passe hashés, géré localement.
# Le motif couvre aussi les sauvegardes (init.ldif.bak, init.ldif.bak-<uid>)
# que setup2.sh --restart-sso-lab laisse derrière lui : elles portent les mêmes
# hachages que l'original.
sso-lab/ldap/init.ldif*
# … mais le gabarit, lui, est versionné.
!sso-lab/ldap/init.ldif.example

# Dossier de debug local
.debug/
