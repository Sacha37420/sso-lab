# Fichiers d'environnement — contiennent des secrets, jamais commités
**/.env
*.env

# Exceptions : les templates sont versionnés
!**/.env.example

# Généré automatiquement par get-ports-list.sh
ports.env

# Registre des ports — géré localement par new-app.sh
.ports
test-angular/
test-django/
test-angular-django/
test-bots/
test-django-angular/
google-agenda/

# Fichier LDAP — contient des mots de passe hashés, géré localement
sso-lab/ldap/init.ldif

# Dossier de debug local
.debug/
