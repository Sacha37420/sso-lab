# ── Adresses ──────────────────────────────────────────────────────
PORT_BACKEND=__BACKEND_PORT__
BACKEND_URL=http://localhost:__BACKEND_PORT__

# ── Base de données ───────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=devdb
DB_SCHEMA=__APP_SLUG__
DB_USER=devuser
DB_PASSWORD=devpassword

# ── Django ────────────────────────────────────────────────────────
SECRET_KEY=<random-secret-key-changez-en-prod>
DEBUG=False
ALLOWED_HOSTS=*

# ── SSO Keycloak ──────────────────────────────────────────────────
# Le backend valide les JWT via JWKS — pas de client secret requis
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/ssolab

# ── URLs (propagées automatiquement par reset_url.sh) ─────────────
PORT_KEYCLOAK=8080
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN
KEYCLOAK_URL=http://192.168.1.X:8080
KEYCLOAK_PUBLIC_URL=http://VOTRE_IP_WAN:8080
