# ── Adresses ──────────────────────────────────────────────────────
PORT_FRONTEND=__FRONTEND_PORT__
FRONTEND_URL=http://localhost:__FRONTEND_PORT__

# ── SSO Keycloak ──────────────────────────────────────────────────
# Client public (SPA Angular) — pas de secret requis côté navigateur
# Créer le client '__APP_SLUG__' dans Keycloak → Access type : Public
# Valid redirect URIs : http://localhost:__FRONTEND_PORT__/*
# Web origins : http://localhost:__FRONTEND_PORT__
KEYCLOAK_CLIENT_ID=__APP_SLUG__
# Pour un client confidentiel (BFF/backend), décommenter et renseigner :
# KEYCLOAK_CLIENT_SECRET=CHANGE_ME
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/ssolab

# ── URLs (propagées automatiquement par reset_url.sh) ─────────────
PORT_KEYCLOAK=8080
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN
KEYCLOAK_URL=http://192.168.1.X:8080
KEYCLOAK_PUBLIC_URL=http://VOTRE_IP_WAN:8080
