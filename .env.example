# ── URLs du serveur ─────────────────────────────────────────────────────────
SERVER_URL_LOCAL=http://localhost
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN

# Keycloak est sur le même hôte que les autres services.
# SERVER_URL_LAN est utilisée comme URL canonique pour les tokens (KC_HOSTNAME_URL).
# KC_HOSTNAME_STRICT=false permet aux 3 contextes d'accéder à Keycloak sans restriction.

# ── HTTPS / Caddy ─────────────────────────────────────────────────────────────
# Laisser DOMAIN=CHANGE_ME pour rester en HTTP (accès direct par port, pas de
# certificat). Pour activer HTTPS :
#   1. Obtenir un nom de domaine pointant vers votre IP WAN (No-IP, DuckDNS…)
#      et configurer sa mise à jour dynamique (DDNS) — entièrement hors de ce
#      dépôt, côté fournisseur DNS ou routeur. Voir la section "Caddy & HTTPS"
#      du README.
#   2. Renseigner DOMAIN et ACME_EMAIL ci-dessous.
#   3. Reporter les mêmes valeurs dans sso-lab/.env (DOMAIN, ACME_EMAIL).
#   4. Lancer : bash scripts/reset_url.sh && bash scripts/setup2.sh --yes
DOMAIN=CHANGE_ME
ACME_EMAIL=CHANGE_ME
