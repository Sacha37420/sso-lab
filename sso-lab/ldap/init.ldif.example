# ─────────────────────────────────────────────────────────────────
# init.ldif.example — Template d'initialisation OpenLDAP
#
# Copier en init.ldif, remplacer les mots de passe CHANGE_ME et
# adapter les emails avant le premier démarrage d'openldap.
#
# Structure :
#   dc=ssolab,dc=local          ← racine (créée automatiquement)
#   └── ou=people               ← utilisateurs
#       ├── uid=sacha
#       ├── uid=Carpeta
#       ├── uid=hassan
#       ├── uid=lea
#       ├── uid=elodie
#       ├── uid=naty
#       ├── uid=maria
#       ├── uid=sabrina
#       └── uid=bruno
#   └── ou=groups               ← groupes
#       ├── cn=developers       ← sacha, hassan        (app : analyse-lora)
#       ├── cn=admins           ← sacha
#       ├── cn=famille          ← sacha, lea, elodie
#       ├── cn=amis             ← sacha, hassan, lea
#       ├── cn=dom              ← naty, maria          (app : google-agenda)
#       ├── cn=harem            ← sacha, Carpeta
#       ├── cn=manager          ← sacha, elodie, sabrina (app : restauration)
#       ├── cn=cuisinier        ← sacha                (app : restauration)
#       └── cn=serveur          ← sacha                (app : restauration)
#
# Groupes requis par les applications (autorisation via le claim JWT "groups") :
#   - analyse-lora  : developers
#   - restauration  : manager, cuisinier, serveur
#   - google-agenda : dom
#   (app-builder, front-cadriciel, traitement-de-fichiers-compils, test-* :
#    authentification seule, aucun groupe imposé)
#
# Le fichier est chargé UNE SEULE FOIS au premier démarrage.
# Pour le recharger : docker compose down --volumes  puis  up
# ─────────────────────────────────────────────────────────────────

# ── Unité organisationnelle : utilisateurs ────────────────────────
dn: ou=people,dc=ssolab,dc=local
objectClass: organizationalUnit
ou: people

# ── Unité organisationnelle : groupes ─────────────────────────────
dn: ou=groups,dc=ssolab,dc=local
objectClass: organizationalUnit
ou: groups

# ── Utilisateur : sacha ───────────────────────────────────────────
# inetOrgPerson = schéma standard pour les personnes (email, prénom…)
# shadowAccount = permet un mot de passe hashé
dn: uid=sacha,ou=people,dc=ssolab,dc=local
objectClass: inetOrgPerson
objectClass: shadowAccount
uid: sacha
cn: Sacha
sn: Sacha
givenName: Sacha
mail: sacha@ssolab.local
# Mot de passe en clair — OpenLDAP le hashera en SHA au démarrage
userPassword: CHANGE_ME

# ── Utilisateur : Carpeta ─────────────────────────────────────────
dn: uid=Carpeta,ou=people,dc=ssolab,dc=local
objectClass: inetOrgPerson
objectClass: shadowAccount
uid: Carpeta
cn: Carpeta
sn: Carpeta
givenName: Carpeta
mail: carpeta@ssolab.local
userPassword: CHANGE_ME

# ── Utilisateur : hassan ──────────────────────────────────────────
dn: uid=hassan,ou=people,dc=ssolab,dc=local
objectClass: inetOrgPerson
