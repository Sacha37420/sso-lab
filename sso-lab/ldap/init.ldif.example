# ── Groupe : developers ───────────────────────────────────────────
# groupOfNames = groupe dont les membres sont des DN complets
dn: cn=developers,ou=groups,dc=ssolab,dc=local
objectClass: groupOfNames
cn: developers
member: uid=sacha,ou=people,dc=ssolab,dc=local
member: uid=hassan,ou=people,dc=ssolab,dc=local

# ── Groupe : admins ───────────────────────────────────────────────
dn: cn=admins,ou=groups,dc=ssolab,dc=local
objectClass: groupOfNames
