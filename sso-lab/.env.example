# URL canonique pour les tokens Keycloak (KC_HOSTNAME_URL)
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN

# ── Mots de passe utilisateurs LDAP ───────────────────────────────
SACHA_PASSWORD=CHANGE_ME
HASSAN_PASSWORD=CHANGE_ME
LEA_PASSWORD=CHANGE_ME
ELODIE_PASSWORD=CHANGE_ME
