# ── Ports exposés ────────────────────────────────────────────────
PORT_LDAP=389
PORT_PHPLDAPADMIN=8081
PORT_KEYCLOAK=8080

# ── LDAP ──────────────────────────────────────────────────────────
LDAP_DOMAIN=ssolab.local
LDAP_ADMIN_PASSWORD=CHANGE_ME
LDAP_CONFIG_PASSWORD=CHANGE_ME

# ── Keycloak ───────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME

# URL canonique pour les tokens Keycloak (KC_HOSTNAME_URL)
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN

# ── Mots de passe utilisateurs LDAP ───────────────────────────────
SACHA_PASSWORD=CHANGE_ME
HASSAN_PASSWORD=CHANGE_ME
LEA_PASSWORD=CHANGE_ME
ELODIE_PASSWORD=CHANGE_ME

# ── SMTP (Keycloak : « mot de passe oublié » + emails) ────────────
#   Gmail : créer un « mot de passe d'application » (compte Google → Sécurité).
#   Tant que SMTP_FROM est vide, le SMTP n'est pas configuré.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_FROM_DISPLAY=SSO Lab
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=

# ── Inscription libre + vérification d'email (realm ssolab) ───────
#   REGISTRATION_ALLOWED=true affiche « Créer un compte » sur la page de login.
#
#   ⚠ NE PAS PASSER À true SANS AVOIR LU CECI. Le lab est exposé sur Internet :
#     n'importe qui pourra s'inscrire. Un inscrit n'obtient aucun groupe LDAP,
#     donc aucun accès tant qu'on ne l'ajoute pas manuellement à un groupe —
#     sauf pour une app qui aurait --require-group vide (à éviter, voir README).
#
#   Laissé à false : le « mot de passe oublié » ci-dessus fonctionne sans lui.
REGISTRATION_ALLOWED=false
#   VERIFY_EMAIL=true impose la validation de l'adresse à la 1re connexion.
#   ⚠ Cela vaut AUSSI pour les comptes LDAP existants : lancer d'abord
#     bash sso-lab/verify-existing-emails.sh (sinon les comptes dont l'adresse
#     @ssolab.local est factice ne pourront plus se connecter).
VERIFY_EMAIL=false

# ── HTTPS / Caddy ──────────────────────────────────────────────────
#   Laisser DOMAIN=CHANGE_ME pour rester en HTTP (accès direct par port).
#   Pour activer HTTPS : obtenir un nom de domaine pointant vers l'IP WAN
#   (No-IP, DuckDNS…) — la mise à jour dynamique de ce domaine (DDNS) est
#   entièrement hors de ce dépôt, à configurer côté fournisseur ou routeur.
#   Voir la section "Caddy & HTTPS" du README.
PORT_HTTP=80
PORT_HTTPS=443
DOMAIN=CHANGE_ME
ACME_EMAIL=CHANGE_ME
# KC_HOSTNAME_URL : URL canonique Keycloak (fixe l'iss des JWT)
# HTTP  → http://IP_WAN:PORT_KEYCLOAK  |  HTTPS → https://DOMAIN/auth
# Mis à jour automatiquement par reset_url.sh — laisser tel quel.
KEYCLOAK_HOSTNAME_URL=CHANGE_ME

# ── code-server + oauth2-proxy ───────────────────────────────────
# Générer ces deux valeurs en exécutant une seule fois (Keycloak démarré) :
#   bash sso-lab/setup-code-server-auth.sh
CODE_SERVER_CLIENT_SECRET=CHANGE_ME
CODE_SERVER_COOKIE_SECRET=CHANGE_ME
# Identité git dans le container (optionnel — défauts : Dev / dev@localhost)
GIT_AUTHOR_NAME=CHANGE_ME
GIT_AUTHOR_EMAIL=CHANGE_ME
